#!/usr/bin/env bash
set -euo pipefail

# Generate the build directory
npm run --silent build

file="publish-files.log"

# Get unique top-level scss directories
git ls-files scss \
  | sed 's#^scss/##' \
  | cut -d/ -f1 \
  | sort -u \
  > "$file"

# Copy files safely
cd scss

while IFS= read -r path; do
  [[ -z "$path" ]] && continue
  cp -rv -- "$path" ..
done < "../$file"

cd -
